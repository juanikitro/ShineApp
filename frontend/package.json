{
  "name": "shineapp-frontend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "generate:changelog": "node scripts/generate-changelog.mjs",
    "predev": "npm run generate:changelog",
    "prebuild": "npm run generate:changelog",
    "pretest": "npm run generate:changelog",
    "dev": "next dev --port 9000",
    "dev:docker": "next dev --hostname 0.0.0.0 --port 3000",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage --maxWorkers=1",
    "test:agenda": "vitest run lib/agenda.test.mjs",
    "test:api-errors": "vitest run lib/api-errors.test.mjs",
    "validate": "npm run test && npm run build",
    "build": "node ./node_modules/next/dist/bin/next build",
    "start": "next start --port 9000",
    "lint": "eslint .",
    "pretypecheck": "npm run generate:changelog",
    "typecheck": "tsc --noEmit",
    "format": "prettier --check .",
    "format:write": "prettier --write ."
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "emoji-picker-react": "^4.19.1",
    "lucide-react": "^0.468.0",
    "motion": "^12.38.0",
    "next": "^15.5.18",
    "pdfjs-dist": "^5.7.284",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "overrides": {
    "postcss": "^8.5.10"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/coverage-v8": "^4.1.6",
    "eslint": "^9.17.0",
    "eslint-config-next": "^15.5.18",
    "eslint-config-prettier": "^9.1.0",
    "jsdom": "^29.1.1",
    "prettier": "^3.4.2",
    "typescript": "^5.7.2",
    "vitest": "^4.1.6"
  }
}
