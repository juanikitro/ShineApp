#!/bin/sh
# ShineApp: regenera CHANGELOG.md y los indices generados en cada commit, para
# que toda implementacion (Claude, Codex o humano) los mantenga al dia.
#
# Habilitar una sola vez por clon:
#   git config core.hooksPath .githooks
# (o ejecutar scripts/setup-hooks.ps1 / scripts/setup-hooks.sh)
set -e

# Resolver Python: Windows usa el launcher `py -3`; Linux/Mac, python3/python.
if command -v py >/dev/null 2>&1; then
  PY="py -3"
elif command -v python3 >/dev/null 2>&1; then
  PY="python3"
elif command -v python >/dev/null 2>&1; then
  PY="python"
else
  echo "pre-commit: no se encontro Python; salteo la regeneracion del changelog." >&2
  echo "pre-commit: CI (job docs) igual valida que no quede desactualizado." >&2
  exit 0
fi

# Regenerar sin build de mkdocs: rapido y sin dependencias extra.
$PY scripts/check_docs.py --write --skip-build >/dev/null

# Reincorporar al commit lo que se haya regenerado (no-op si no cambio nada).
# changelog.generated.json esta en .gitignore (se genera en prebuild de Next.js).
#
# En feature branches NO se agregan los archivos generados: cada branch los
# regenera con solo sus propios fragmentos, y commitearlos causa conflictos
# inevitables entre PRs concurrentes. En main/development si se agregan,
# porque CI (regen-docs.yml) los mantiene al dia despues de cada merge.
CURRENT_BRANCH=$(git symbolic-ref --short HEAD 2>/dev/null || echo "")
case "$CURRENT_BRANCH" in
  main|development)
    git add CHANGELOG.md \
      docs/registro/cambios/index.md \
      docs/registro/decisiones/index.md \
      docs/plans/index.md
    ;;
esac
