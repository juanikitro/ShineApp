# Django runtime
APP_ENVIRONMENT=local
DJANGO_SETTINGS_MODULE=config.settings
DJANGO_SECRET_KEY=change-me-local-only
DJANGO_DEBUG=1
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,backend
CORS_ALLOWED_ORIGINS=http://localhost:9000,http://127.0.0.1:9000
CORS_ALLOWED_ORIGIN_REGEXES=
CSRF_TRUSTED_ORIGINS=http://localhost:9000,http://127.0.0.1:9000
DATABASE_SSL_REQUIRE=0
DJANGO_THROTTLE_ANON_RATE=60/min
DJANGO_THROTTLE_USER_RATE=600/min

# Logging estructurado. json en prod (capturado por Vercel), plain legible en local.
LOG_FORMAT=plain
DJANGO_LOG_LEVEL=WARNING
# Timeout de conexion a la DB en segundos (evita requests colgados).
DATABASE_CONNECT_TIMEOUT=10

# Local host ports published by Docker Compose.
SHINEAPP_FRONTEND_PORT=9000
SHINEAPP_BACKEND_PORT=9001
SHINEAPP_DB_PORT=9002

# Production observability and edge protection. Use real values only in Vercel/GitHub dashboards.
SENTRY_DSN=
SENTRY_ENVIRONMENT=local
SENTRY_RELEASE=
SENTRY_TRACES_SAMPLE_RATE=0
SENTRY_SEND_DEFAULT_PII=0
WAF_PROVIDER=manual
WAF_STATUS=not-configured

# Local Docker Postgres fallback. In Vercel/Supabase prefer DATABASE_URL.
DATABASE_URL=
POSTGRES_DB=shineapp
POSTGRES_USER=shineapp
POSTGRES_PASSWORD=shineapp
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Supabase Storage S3 for persistent media. Keep disabled for plain local dev.
SUPABASE_STORAGE_ENABLED=0
SUPABASE_STORAGE_BUCKET=shineapp-media
SUPABASE_S3_ENDPOINT_URL=https://<project-ref>.storage.supabase.co/storage/v1/s3
SUPABASE_S3_REGION_NAME=<supabase-region>
SUPABASE_S3_ACCESS_KEY_ID=<server-side-access-key-id>
SUPABASE_S3_SECRET_ACCESS_KEY=<server-side-secret-access-key>
SUPABASE_STORAGE_QUERYSTRING_AUTH=0
SUPABASE_STORAGE_PUBLIC_URL=https://<project-ref>.supabase.co/storage/v1/object/public/shineapp-media
SUPABASE_STORAGE_LOCATION=media

# Business defaults
DEFAULT_DAILY_CAPACITY=8
BUSINESS_NAME=ShineApp

# Email
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=1
EMAIL_TIMEOUT=10
DEFAULT_FROM_EMAIL=no-reply@shineapp.local

# Operabilidad y mantenimiento
# Base publica del frontend para links en emails (reset, bienvenida, avisos).
FRONTEND_BASE_URL=https://shineapp-web.vercel.app
# Secret compartido para el endpoint /api/internal/maintenance/ (cron de GitHub
# Actions). Vacio = endpoint deshabilitado. En prod, un valor aleatorio largo.
CRON_SECRET=
# Timeout del envio de web push en segundos.
PUSH_TIMEOUT_SECONDS=10
# Retencion de papelera (soft-delete) en dias antes de poder purgar.
TRASH_RETENTION_DAYS=90
# El mantenimiento solo purga la papelera de verdad si esto es 1; si no, reporta.
MAINTENANCE_PURGE_ENABLED=0

# Web Push (VAPID). Generar con: npx web-push generate-vapid-keys
# VAPID_PUBLIC_KEY y NEXT_PUBLIC_VAPID_PUBLIC_KEY deben coincidir.
# Dejar vacíos para deshabilitar push notifications.
VAPID_PRIVATE_KEY=
VAPID_PUBLIC_KEY=
VAPID_CLAIMS_EMAIL=mailto:no-reply@shineapp.local

# Next.js public env. This value is bundled into the browser.
NEXT_PUBLIC_API_URL=http://localhost:9001/api
NEXT_PUBLIC_SHINEAPP_DEMO_LOGIN=1
NEXT_PUBLIC_SHINEAPP_DEMO_USERNAME=admin
NEXT_PUBLIC_SHINEAPP_TOKEN_TTL_DAYS=30
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
